{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "composite": true,
    "strict": true,
    "emitDeclarationOnly": true,
    "declaration": true,
    "skipLibCheck": true,
    "types": ["node"],
    "lib": ["ES2021", "DOM"]
  },
  "include": ["e2e/**/*.ts", "playwright.config.ts"]
}
