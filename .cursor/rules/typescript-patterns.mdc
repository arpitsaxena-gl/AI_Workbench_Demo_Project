# TypeScript Patterns

## Types vs Interfaces

Use `interface` for object shapes, props, and extending types:
```typescript
interface ButtonProps {
  title: string
  onClick: () => void
  disabled?: boolean
}
```

Use `type` for unions, primitives, and mapped types:
```typescript
type Status = 'active' | 'inactive'
type ID = string | number
```

## Nullability

```typescript
// Optional chaining
const name = user?.profile?.name

// Prefer nullish coalescing (??) over ||
const count = value ?? 0  // preserves 0, '', false
```

## Type Guards

```typescript
function isError(result: Result): result is ErrorResult {
  return result.status === 'error'
}
```

## React Event Types

```typescript
// Form events
const handleSubmit = (e: React.FormEvent<HTMLFormElement>) => {
  e.preventDefault()
}

// Input change events
const handleChange = (e: React.ChangeEvent<HTMLInputElement>) => {
  setValue(e.target.value)
}

// Click events
const handleClick = (e: React.MouseEvent<HTMLButtonElement>) => {
  // handle click
}
```

## Import Path Aliases

Prefer `@/` over relative imports when navigating more than one level:
```typescript
// Good
import { Button } from "@/components/shared/Button"

// Avoid
import { Button } from "../../../components/shared/Button"
```

## Generic Components

```typescript
interface ListProps<T> {
  items: T[]
  renderItem: (item: T) => React.ReactNode
}

function List<T>({ items, renderItem }: ListProps<T>) {
  return <ul>{items.map(renderItem)}</ul>
}
```
