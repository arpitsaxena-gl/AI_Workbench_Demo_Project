{
  "name": "my-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=backend --filter=frontend",
    "dev:frontend": "turbo run dev --filter=frontend",
    "dev:backend": "turbo run dev --filter=backend",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "bootstrap": "npm install",
    "test:e2e": "playwright test",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"e2e/**/*.ts\" \"*.{json,ts}\"",
    "test:coverage": "vitest run --coverage",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "npx tsx e2e/cleanup-screenshots.ts && cross-env PLAYWRIGHT_SLOW_MO=1000 playwright test --headed --project=chromium --workers=1",
    "test:e2e:report": "playwright show-report",
    "test:e2e:clean": "npx tsx e2e/cleanup-screenshots.ts"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "prettier": "^3.7.4",
    "turbo": "^2.8.17",
    "typescript": "5.9.2",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}